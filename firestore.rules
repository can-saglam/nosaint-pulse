rules_version = '2';

// Pulse stores all surveys in a single document: pulse/state
// This rule allows any *signed-in* client (the app signs in anonymously) to
// read and write that one document, and nothing else.
//
// This is fine for non-sensitive survey *definitions* shared by a small team.
// To lock it to specific people instead, enable Google sign-in and replace the
// condition with e.g.:
//   allow read, write: if request.auth.token.email in [
//     'you@example.com', 'teammate@example.com'
//   ];
service cloud.firestore {
  match /databases/{database}/documents {
    match /pulse/state {
      allow read, write: if request.auth != null;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
